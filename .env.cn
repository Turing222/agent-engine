# ==========================================
# Agent Engine - 【国内环境】配置文件
# 无需翻墙，全境低延迟直连
# 运行方式: uv run --env-file .env.cn uvicorn app.main:app ...
# ==========================================

# ── 1. 大模型推理层 (DeepSeek / 阿里千问 等) ──
LLM_PROVIDER=openai
LLM_API_KEY=sk-xxxxxx-deepseek-key-here
LLM_BASE_URL=https://api.deepseek.com/v1

# ── 2. 在线搜索集成 (博查 Bocha 等国内 API) ──
TAVILY_API_KEY=tvly-xxxxxx-实际上可以配置为国内平替服务的-key

# ── 3. 可观测性 (本地 Langfuse / Phoenix) ──
# 国内网络连接外网 Pydantic Logfire 服务器较慢，这里指定为本地大屏
LOGFIRE_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # 指向本地的私有化遥测大屏

# ── 4. 与 MLOps 的架构交互层 ──
MLOPS_API_URL=http://localhost:8000/v1
