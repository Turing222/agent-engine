# ==========================================
# Agent Engine - 【海外/全局环境】配置文件
# 需要全局代理或运行在海外服务器
# 运行方式: uv run --env-file .env.global uvicorn app.main:app ...
# ==========================================

# ── 1. 大模型推理层 (Gemini / OpenAI 官方 / Anthropic) ──
LLM_PROVIDER=gemini
LLM_API_KEY=AIzaSy-xxxxxx-your-gemini-key
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── 2. 在线搜索集成 (Tavily 原生外网版) ──
TAVILY_API_KEY=tvly-xxxxxx-your-tavily-key-here

# ── 3. 可观测性 (Pydantic Logfire 官方云) ──
LOGFIRE_TOKEN=logfire_xxxxxx-your-logfire-token-here

# ── 4. 与 MLOps 的架构交互层 ──
MLOPS_API_URL=http://localhost:8000/v1
